#!/bin/bash

# --- Formatting Helpers ---
BOLD='\033[1m'
GREEN='\033[0;32m'
RED='\033[0;31m'
YELLOW='\033[0;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

ZSHRC="$HOME/.zshrc"


echo -e "\n${BLUE}${BOLD}🚀 Starting YADM Bootstrap Setup...${NC}"
echo -e "\n${YELLOW}${BOLD}💡 Compatible with Debian based OS !${NC}"
echo

# --- 0. Environment Detection ---
IS_WSL=false
if grep -qi microsoft /proc/version; then
    IS_WSL=true
    echo -e "${BLUE}ℹ Detected WSL Environment${NC}\n"
fi

# --- 1. ZSH & Oh My Zsh ---
echo -e "${BOLD}1. ZSH & Oh My Zsh${NC}"

# Check for ZSH
if command -v zsh >/dev/null 2>&1; then
    echo -e "  ${GREEN}✔${NC} ZSH is installed."
    ZSH_INSTALLED=true
else
    echo -e "  ${RED}✘ ZSH is MISSING${NC}"
    echo -e "\n${YELLOW}STOPPING BOOTSTRAP:${NC} ZSH is required to continue."
    echo -e "👉 Install it using: ${BOLD}sudo apt install zsh${NC}"
    echo -e "Then, run this bootstrap script again."
    exit 1
fi

# Check for Oh My Zsh
if [ -d "$HOME/.oh-my-zsh" ]; then
    echo -e "  ${GREEN}✔${NC} Oh My Zsh is installed."
else
    echo -e "  ${RED}✘ Oh My Zsh is MISSING${NC}"
    echo -e "\n${YELLOW}STOPPING BOOTSTRAP:${NC} Oh My Zsh is required for plugin management."
    echo -e "👉 Install it using:"
    echo -e "${BLUE}sh -c \"\$(curl -fsSL https://raw.githubusercontent.com/ohmyzsh/ohmyzsh/master/tools/install.sh)\"${NC}"
    echo -e "\nAfter installation, re-run this bootstrap script."
    exit 1
fi

# --- 2. Starship Prompt ---
echo -e "${BOLD}2. Starship Prompt${NC}"
if command -v starship >/dev/null 2>&1; then
    echo -e "  ${GREEN}✔${NC} Starship is installed."
else
    echo -e "  ${RED}✘ Starship is MISSING${NC}"
    read -p "    ❓ Install Starship now? (y/n) " -n 1 -r
    echo ""
    if [[ $REPLY =~ ^[Yy]$ ]]; then
        curl -sS https://starship.rs/install.sh | sh -s -- -y
    else
        echo -e "    👉 Manual Guide: ${YELLOW}curl -sS https://starship.rs/install.sh | sh${NC}"
    fi
fi

# Add to .zshrc if installed
if command -v starship >/dev/null 2>&1 && [ "$ZSH_INSTALLED" = true ]; then
    if ! grep -q "starship init zsh" "$ZSHRC"; then
        echo -e "  ${BLUE}⏳ Adding Starship init to .zshrc...${NC}"
        echo 'eval "$(starship init zsh)"' >> "$ZSHRC"
    fi
fi
echo ""

# --- 3. Plugins ---
echo -e "${BOLD}3. Plugins${NC}"
PLUG_DIR="${ZSH_CUSTOM:-$HOME/.oh-my-zsh/custom}/plugins"
MISSING_PLUGINS=()

check_plugin() {
    local name=$1
    local url=$2
    if [ -d "$PLUG_DIR/$name" ]; then
        echo -e "  ${GREEN}✔${NC} Plugin $name is installed."
    else
        echo -e "  ${RED}✘ Plugin $name is MISSING${NC}"
        MISSING_PLUGINS+=("$name|$url")
    fi
}

check_plugin "zsh-syntax-highlighting" "https://github.com/zsh-users/zsh-syntax-highlighting.git"
check_plugin "zsh-autosuggestions" "https://github.com/zsh-users/zsh-autosuggestions"
check_plugin "zsh-history-substring-search" "https://github.com/zsh-users/zsh-history-substring-search"

if [ ${#MISSING_PLUGINS[@]} -gt 0 ]; then
    read -p "  ❓ Install missing plugins? (y/n) " -n 1 -r
    echo ""
    if [[ $REPLY =~ ^[Yy]$ ]]; then
        for plug_info in "${MISSING_PLUGINS[@]}"; do
            name=$(echo $plug_info | cut -d'|' -f1)
            url=$(echo $plug_info | cut -d'|' -f2)
            echo -e "    ⏳ Cloning $name..."
            git clone --depth 1 "$url" "$PLUG_DIR/$name"
        done
    else
        echo -e "    👉 Manual Guide: ${YELLOW}git clone [URL] \$ZSH_CUSTOM/plugins/[NAME]${NC}"
    fi
fi

# Add plugins to .zshrc config line if ZSH is present
if [ "$ZSH_INSTALLED" = true ] && [ -f "$ZSHRC" ]; then
    # This logic checks if plugins are in the plugins=(...) list in .zshrc
    for plug_info in "zsh-syntax-highlighting" "zsh-autosuggestions" "zsh-history-substring-search"; do
        if ! grep -qP "^plugins=\(.*\b$plug_info\b.*\)" "$ZSHRC"; then
             echo -e "  ${YELLOW}ℹ $plug_info not found in .zshrc plugins list.${NC}"
             echo -e "    👉 Please add it manually to the ${BOLD}plugins=(...)${NC} section."
        fi
    done
fi
echo ""

# --- 4. Fonts (Nerd Fonts via getnf) ---
echo -e "${BOLD}4. Nerd Fonts${NC}"
GETNF_PATH="$HOME/.local/bin/getnf"

if [ "$IS_WSL" = true ]; then
    echo -e "  ${YELLOW}ℹ WSL Reminder: Install Nerd Fonts on WINDOWS (the host) to see icons.${NC}"
fi

if [ -f "$GETNF_PATH" ]; then
    echo -e "  ${GREEN}✔${NC} getnf found."
    read -p "    ❓ Run getnf now? (y/n) " -n 1 -r
    echo ""
    if [[ $REPLY =~ ^[Yy]$ ]]; then $GETNF_PATH; fi
else
    read -p "    ❓ Install getnf? (y/n) " -n 1 -r
    echo ""
    if [[ $REPLY =~ ^[Yy]$ ]]; then
        git clone --depth 1 https://github.com/getnf/getnf.git /tmp/getnf
        cd /tmp/getnf && ./install.sh
        $GETNF_PATH
    fi
fi

echo -e "\n${BLUE}${BOLD}✨ YADM Bootstrap Setup Complete!${NC}"
echo
