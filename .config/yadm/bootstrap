#!/bin/bash

# --- Formatting Helpers ---
BOLD='\033[1m'
GREEN='\033[0;32m'
RED='\033[0;31m'
YELLOW='\033[0;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

echo -e "${BLUE}${BOLD}🚀 Starting Terminal Health Check...${NC}"

# --- 0. Environment Detection ---
IS_WSL=false
if grep -qi microsoft /proc/version; then
    IS_WSL=true
    echo -e "${BLUE}ℹ Detected WSL Environment${NC}\n"
fi

# --- 1. ZSH & Oh My Zsh ---
echo -e "${BOLD}1. ZSH & Oh My Zsh${NC}"
if command -v zsh >/dev/null 2>&1; then
    echo -e "  ${GREEN}✔${NC} ZSH is installed."
else
    echo -e "  ${RED}✘ ZSH is MISSING${NC}"
    echo -e "    👉 Guide: ${YELLOW}sudo apt install zsh${NC}"
fi

if [ -d "$HOME/.oh-my-zsh" ]; then
    echo -e "  ${GREEN}✔${NC} Oh My Zsh is installed."
else
    echo -e "  ${RED}✘ Oh My Zsh is MISSING${NC}"
    echo -e "    👉 Guide: ${YELLOW}sh -c \"\$(curl -fsSL https://raw.githubusercontent.com/ohmyzsh/ohmyzsh/master/tools/install.sh)\"${NC}"
fi

# --- 1.5 ZSH Theme Check (Conflict Prevention) ---
ZSHRC="$HOME/.zshrc"
if [ -f "$ZSHRC" ]; then
    # Extract active theme (ignoring commented lines)
    CURRENT_THEME=$(grep "^ZSH_THEME=" "$ZSHRC" | cut -d'"' -f2)

    if [ -n "$CURRENT_THEME" ]; then
        echo -e "\n  ${YELLOW}⚠ Conflict Check: ZSH theme is set to \"$CURRENT_THEME\"${NC}"
        echo -e "    Note: Starship works best when ZSH_THEME=\"\""
        read -p "    ❓ Disable current theme? (y/n) " -n 1 -r
        echo ""
        if [[ $REPLY =~ ^[Yy]$ ]]; then
            # GNU sed compatible with WSL/Linux
            sed -i 's/^ZSH_THEME=.*/ZSH_THEME=""/' "$ZSHRC"
            echo -e "  ${GREEN}✔${NC} Theme disabled in .zshrc."
        else
            echo -e "  ${BLUE}ℹ${NC} Keeping current theme."
        fi
    fi
fi
echo ""

# --- 2. Starship Prompt ---
echo -e "${BOLD}2. Starship Prompt${NC}"
if command -v starship >/dev/null 2>&1; then
    echo -e "  ${GREEN}✔${NC} Starship is installed. ($(starship --version | head -n 1))"
else
    echo -e "  ${RED}✘ Starship is MISSING${NC}"
    echo -e "    👉 Guide: ${YELLOW}curl -sS https://starship.rs/install.sh | sh -s -- -y${NC}"
fi
echo ""

# --- 3. Plugins ---
echo -e "${BOLD}3. Plugins${NC}"
PLUG_DIR="${ZSH_CUSTOM:-$HOME/.oh-my-zsh/custom}/plugins"

check_plugin() {
    local name=$1
    local url=$2
    if [ -d "$PLUG_DIR/$name" ]; then
        echo -e "  ${GREEN}✔${NC} Plugin $name is installed."
    else
        echo -e "  ${RED}✘ Plugin $name is MISSING${NC}"
        echo -e "    👉 Guide: ${YELLOW}git clone $url \$ZSH_CUSTOM/plugins/$name${NC}"
    fi
}

check_plugin "zsh-syntax-highlighting" "https://github.com/zsh-users/zsh-syntax-highlighting.git"
check_plugin "zsh-autosuggestions" "https://github.com/zsh-users/zsh-autosuggestions"
check_plugin "zsh-history-substring-search" "https://github.com/zsh-users/zsh-history-substring-search"
echo ""

# --- 4. Fonts (Nerd Fonts via getnf) ---
echo -e "${BOLD}4. Nerd Fonts${NC}"
GETNF_PATH="$HOME/.local/bin/getnf"

if [ "$IS_WSL" = true ]; then
    echo -e "  ${YELLOW}ℹ WSL Reminder: Install Nerd Fonts on WINDOWS (the host) to see icons.${NC}"
fi

if [ -f "$GETNF_PATH" ]; then
    echo -e "  ${GREEN}✔${NC} getnf found at $GETNF_PATH"
    read -p "  ❓ Run getnf now to manage fonts? (y/n) " -n 1 -r
    echo ""
    if [[ $REPLY =~ ^[Yy]$ ]]; then
        $GETNF_PATH
    fi
else
    read -p "  ❓ getnf not found. Would you like to install it? (y/n) " -n 1 -r
    echo ""
    if [[ $REPLY =~ ^[Yy]$ ]]; then
        echo -e "  ${BLUE}⏳ Installing getnf...${NC}"
        git clone --depth 1 https://github.com/getnf/getnf.git /tmp/getnf
        cd /tmp/getnf && ./install.sh
        echo -e "  ${GREEN}✔${NC} getnf installed."
        $GETNF_PATH
    else
        echo -e "  ${YELLOW}⚠ Skipping font installation tool.${NC}"
    fi
fi

echo -e "\n${BLUE}${BOLD}✨ Health Check Complete!${NC}"
